---
import { KNOWN_CIRCULATING_TOKENS, MAX_SUPPLY_TOKENS } from '../web3/constants';

interface Props {
    locale?: 'en' | 'pt-BR';
}
const { locale = 'pt-BR' } = Astro.props;
const pt = locale === 'pt-BR';
const numberLocale = pt ? 'pt-BR' : 'en-US';
const supplyPctWidth = MAX_SUPPLY_TOKENS > 0 ? (KNOWN_CIRCULATING_TOKENS / MAX_SUPPLY_TOKENS) * 100 : 0;
const supplyCountInitial = KNOWN_CIRCULATING_TOKENS.toLocaleString(numberLocale);
---
<section class="bento-section" id="tokenomics">
    <div class="wrap">
        <div class="section-eyebrow">{pt ? '01 — Mint e tokenomics' : '01 — Mint & tokenomics'}</div>
        <div class="section-title" id="features">
            {pt ? (
                <>
                    <span>Mint em tempo real na Base</span><br />
                    <span style="font-weight:500;color:var(--text-2);font-size:0.9em;">
                        Contrato verificado · Assegure seu $NEOFLW agora
                    </span>
                </>
            ) : (
                <>
                    <span>Official $NEOFLW mint on Base</span><br />
                    <span style="font-weight:500;color:var(--text-2);font-size:0.9em;">
                        Verified contract · Secure your $NEOFLW now
                    </span>
                </>
            )}
        </div>

        <div class="bento">

            <div class="bc bc-supply bc-w8 interactive-mint" id="mint">
                <div class="bc-label">{pt ? 'JÁ MINTADOS:' : 'ALREADY MINTED:'}</div>
                <div class="bc-number-huge" id="supply-count">{supplyCountInitial}</div>
                <div class="bc-sublabel">
                    {pt
                        ? `$NEOFLW de um total máximo de 1.000.000.000. Apenas 1 mint por wallet.`
                        : `${supplyCountInitial} $NEOFLW already minted out of a 1,000,000,000 max supply. One mint per wallet.`}
                </div>

                <div class="supply-progress">
                    <div class="supply-bar" id="supply-bar" style={`width:${Math.min(100, supplyPctWidth)}%`}></div>
                </div>

                <div class="mint-card">
                    <div class="mint-stats">
                        <div class="mint-stat">
                            <span class="stat-label">{pt ? 'Quantidade de Mint' : 'Mint Amount'}</span>
                            <span class="stat-value" id="info-amount">1,000 $NEOFLW</span>
                        </div>
                        <div class="mint-stat">
                            <span class="stat-label">{pt ? 'Preço' : 'Price'}</span>
                            <span class="stat-value" id="info-price">0.003 ETH</span>
                        </div>
                    </div>
                    <div class="mint-actions">
                        <button type="button" class="mint-btn" id="action-mint-btn" style="text-decoration:none;display:flex;align-items:center;justify-content:center;">
                            {pt ? 'Mint Agora' : 'Mint Now'}
                        </button>
                    </div>
                </div>
            </div>

            <a class="bc bc-w12 tech-cta" href={pt ? '/tech' : '/en/tech'}>
                <div class="tech-cta-inner">
                    <div class="tech-cta-eyebrow">{pt ? 'Defesa Técnica Completa' : 'Full Technical Defense'}</div>
                    <div class="tech-cta-title">
                        {pt ? 'Verificação, padrões e arquitetura do contrato' : 'Verification, standards & contract architecture'}
                    </div>
                    <div class="tech-cta-desc">
                        {pt
                            ? 'Rede Base L2 · Contrato verificado na Basescan · Stack OpenZeppelin · Interface Solidity · Garantias de segurança.'
                            : 'Base L2 network · Verified on Basescan · OpenZeppelin stack · Solidity interface · Security guarantees.'}
                    </div>
                </div>
                <div class="tech-cta-arrow" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:22px;height:22px;"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                </div>
            </a>
         </div>
    </div>
</section>

<style>
    @media (min-width: 860px) {
        .bc-supply.interactive-mint {
            grid-column: 3 / span 8;
        }
    }

    .tech-cta {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        text-decoration: none;
        color: inherit;
        background: linear-gradient(135deg, rgba(0, 82, 255, 0.12) 0%, rgba(255, 0, 204, 0.1) 100%);
        border: 1px solid rgba(0, 82, 255, 0.3);
        transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .tech-cta:hover {
        transform: translateY(-2px);
        border-color: rgba(0, 82, 255, 0.6);
        box-shadow: 0 10px 30px -10px rgba(0, 82, 255, 0.35);
    }
    .tech-cta-inner {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        flex: 1 1 auto;
        min-width: 0;
    }
    .tech-cta-eyebrow {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--blue);
        font-weight: 800;
    }
    .tech-cta-title {
        font-size: clamp(1.05rem, 2.2vw, 1.35rem);
        font-weight: 700;
        color: var(--text);
        line-height: 1.25;
    }
    .tech-cta-desc {
        font-size: 0.82rem;
        color: var(--text-2);
        line-height: 1.55;
    }
    .tech-cta-arrow {
        flex: 0 0 auto;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: rgba(0, 82, 255, 0.18);
        color: var(--blue);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease, background 0.2s ease;
    }
    .tech-cta:hover .tech-cta-arrow {
        transform: translateX(4px);
        background: rgba(0, 82, 255, 0.3);
    }
    @media (max-width: 560px) {
        .tech-cta { gap: 0.85rem; }
        .tech-cta-arrow { width: 40px; height: 40px; }
    }
</style>
