---
import { Image } from 'astro:assets';
import neoflwLogo from '../assets/neoflw.png';
import NavConnect from './web3/NavConnect.tsx';

interface Props {
    locale?: 'en' | 'pt-BR';
}
const { locale = 'pt-BR' } = Astro.props;
const pt = locale === 'pt-BR';
const mintPath = pt ? '/mint' : '/en/mint';
const techPath = pt ? '/tech' : '/en/tech';
const switchPath = pt ? '/en/' : '/';
const homePath = pt ? '/' : '/en/';
---
<nav>
    <div class="nav-pill">
        <div class="nav-inner">
            <a href={homePath} class="nav-logo" aria-label="NEØ FlowOFF — Home">
                <Image src={neoflwLogo} alt="" width={28} height={28} loading="eager" class="nav-logo-img" />
                <span class="nav-logo-text"><span class="neo">NEØ</span> FlowOFF</span>
            </a>

            <input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-hidden="true" tabindex="-1" />
            <label for="nav-toggle" class="nav-toggle" aria-label={pt ? 'Abrir menu' : 'Open menu'}>
                <span class="nav-toggle-bar" aria-hidden="true"></span>
                <span class="nav-toggle-bar" aria-hidden="true"></span>
                <span class="nav-toggle-bar" aria-hidden="true"></span>
                <span class="sr-only">{pt ? 'Menu' : 'Menu'}</span>
            </label>

            <ul class="nav-links">
                <li><a href={`${homePath}#tokenomics`}>{pt ? 'Tokenomics' : 'Tokenomics'}</a></li>
                <li><a href={`${homePath}#features`}>{pt ? 'Recursos' : 'Features'}</a></li>
                <li><a href={`${homePath}#chart`}>{pt ? 'Gráfico' : 'Chart'}</a></li>
                <li><a href={`${homePath}#verify`}>{pt ? 'Verificação' : 'Verify'}</a></li>
                <li><a href={techPath}>{pt ? 'Tecnologia' : 'Tech'}</a></li>
                <li><a href={mintPath} class="nav-special">Mint</a></li>
                <li>
                    <a
                        href={switchPath}
                        class="nav-special nav-lang"
                        aria-label={pt ? 'Switch to English' : 'Mudar para Português'}
                        title={pt ? 'English' : 'Português'}
                    >
                        {pt ? (
                            <svg class="nav-flag" viewBox="0 0 60 40" aria-hidden="true" focusable="false">
                                <rect width="60" height="40" fill="#B22234" />
                                <rect y="3" width="60" height="3" fill="#fff" />
                                <rect y="9" width="60" height="3" fill="#fff" />
                                <rect y="15" width="60" height="3" fill="#fff" />
                                <rect y="21" width="60" height="3" fill="#fff" />
                                <rect y="27" width="60" height="3" fill="#fff" />
                                <rect y="33" width="60" height="3" fill="#fff" />
                                <rect width="24" height="21" fill="#3C3B6E" />
                                <g fill="#fff">
                                    <circle cx="4" cy="4" r="0.9" /><circle cx="10" cy="4" r="0.9" /><circle cx="16" cy="4" r="0.9" /><circle cx="22" cy="4" r="0.9" />
                                    <circle cx="7" cy="8" r="0.9" /><circle cx="13" cy="8" r="0.9" /><circle cx="19" cy="8" r="0.9" />
                                    <circle cx="4" cy="12" r="0.9" /><circle cx="10" cy="12" r="0.9" /><circle cx="16" cy="12" r="0.9" /><circle cx="22" cy="12" r="0.9" />
                                    <circle cx="7" cy="16" r="0.9" /><circle cx="13" cy="16" r="0.9" /><circle cx="19" cy="16" r="0.9" />
                                </g>
                            </svg>
                        ) : (
                            <svg class="nav-flag" viewBox="0 0 60 42" aria-hidden="true" focusable="false">
                                <rect width="60" height="42" fill="#009c3b" />
                                <polygon points="30,4 56,21 30,38 4,21" fill="#ffdf00" />
                                <circle cx="30" cy="21" r="7.8" fill="#002776" />
                                <path d="M22.5 20.5 Q30 17 37.5 20.5" stroke="#fff" stroke-width="0.8" fill="none" />
                            </svg>
                        )}
                        <span class="sr-only">{pt ? 'EN' : 'PT'}</span>
                    </a>
                </li>
            </ul>

            <NavConnect client:only="react" />
        </div>
    </div>
</nav>

<style is:global>
    .nav-lang {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.3rem 0.55rem !important;
        line-height: 0;
    }
    .nav-flag {
        width: 22px;
        height: auto;
        border-radius: 3px;
        box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.18), 0 1px 3px rgba(0, 0, 0, 0.35);
        display: block;
        transition: transform 0.2s ease;
    }
    .nav-lang:hover .nav-flag { transform: scale(1.08); }
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }
</style>

<script is:inline>
    (() => {
        const toggle = document.getElementById('nav-toggle');
        if (!toggle) return;
        document.querySelectorAll('.nav-links a').forEach((link) => {
            link.addEventListener('click', () => {
                toggle.checked = false;
            });
        });
        document.addEventListener('click', (e) => {
            if (!toggle.checked) return;
            const inner = document.querySelector('.nav-inner');
            if (inner && !inner.contains(e.target)) toggle.checked = false;
        });
    })();
</script>
