---
interface Props {
    locale?: 'en' | 'pt-BR';
}
const { locale = 'en' } = Astro.props;
const pt = locale === 'pt-BR';
const mintPath = pt ? '/pt-br/mint' : '/mint';
const switchPath = pt ? '/' : '/pt-br/';
const homePath = pt ? '/pt-br/' : '/';
---
<nav>
    <div class="nav-pill">
        <div class="nav-inner">
            <a href={homePath} class="nav-logo"><span class="neo">NEØ</span> FlowOFF</a>
            <ul class="nav-links">
                <li><a href="#tokenomics">{pt ? 'Tokenomics' : 'Tokenomics'}</a></li>
                <li><a href="#features">{pt ? 'Recursos' : 'Features'}</a></li>
                <li><a href="#chart">{pt ? 'Gráfico' : 'Chart'}</a></li>
                <li><a href="#verify">{pt ? 'Verificação' : 'Verify'}</a></li>
                <li><a href={mintPath} class="nav-special">Mint</a></li>
                <li><a href={switchPath} class="nav-special">{pt ? 'EN' : 'PT'}</a></li>
            </ul>
            <button id="connect-btn" class="nav-wallet-btn">
                <span class="dot"></span> {pt ? 'Conectar Wallet' : 'Connect Wallet'}
            </button>
        </div>
    </div>
</nav>
