---
import Layout from '../layouts/Layout.astro';
import Nav from './Nav.astro';
import HeroSection from './HeroSection.astro';
import ProofSection from './ProofSection.astro';
import StatsBar from './StatsBar.astro';
import TokenomicsSection from './TokenomicsSection.astro';
import ChartSection from './ChartSection.astro';
import VerifySection from './VerifySection.astro';
import Footer from './Footer.astro';

interface Props {
  locale?: 'en' | 'pt-BR';
}
const { locale = 'en' } = Astro.props;
const pt = locale === 'pt-BR';
const numberLocale = pt ? 'pt-BR' : 'en-US';
const layoutTitle = pt ? 'NEOFLW - Token NEØ FLOWOFF' : 'NEOFLW - NEØ FLOWOFF Token';
const layoutDescription = pt
  ? 'NEOFLW é o token nativo do ecossistema NEØ FLOWOFF. ERC-20 na Base mainnet.'
  : 'NEOFLW is the native token of the NEØ FLOWOFF ecosystem. ERC-20 on Base mainnet.';
const i18n = {
  connectWallet: pt ? 'Conectar Wallet' : 'Connect Wallet',
  chooseWallet: pt ? 'Escolha sua wallet' : 'Choose your wallet',
  cancel: pt ? 'Cancelar' : 'Cancel',
  opensMetaMask: pt ? 'Abre o app da MetaMask' : 'Opens MetaMask app',
  opensCoinbase: pt ? 'Abre o app da Coinbase Wallet' : 'Opens Coinbase Wallet app',
  opensUniswap: pt ? 'Abre o app da Uniswap' : 'Opens Uniswap app',
  opensRainbow: pt ? 'Abre o app da Rainbow' : 'Opens Rainbow app',
  alreadyMinted: pt ? 'Mint já realizado' : 'Already Minted',
  mintNow: pt ? 'Mint Agora' : 'Mint Now',
  connectWalletToMint: pt ? 'Conecte a Wallet para Mint' : 'Connect Wallet to Mint',
  mintingDisabled: pt ? 'Mint Desativado' : 'Minting Disabled',
  checkingBalance: pt ? 'Verificando saldo...' : 'Checking Balance...',
  processingTx: pt ? 'Processando transação...' : 'Processing Transaction...',
  waitingConfirmation: pt ? 'Aguardando confirmação...' : 'Waiting Confirmation...',
  success: pt ? '✓ Sucesso!' : '✓ Success!',
  txFailed: pt ? 'Transação falhou. Tente novamente.' : 'Transaction failed. Please try again.',
  rejected: pt ? 'Usuário rejeitou conexão ou assinatura.' : 'User rejected connection or signature.',
  networkError: pt ? 'Erro de rede: confirme que você está na Base Mainnet.' : 'Network error: Please ensure you are on Base Mainnet.',
  installWallet: pt ? 'Instale MetaMask ou outra extensão de wallet Web3.' : 'Please install MetaMask or another Web3 wallet extension.',
  walletNotFound: pt ? 'Wallet Web3 não encontrada. Instale a MetaMask.' : 'Web3 wallet not found. Please install MetaMask.',
  rejectedTx: pt ? 'Usuário rejeitou a transação.' : 'User rejected transaction.',
  lowBalance: pt ? 'Saldo da wallet insuficiente para cobrir Mint Price + Gas.' : 'Wallet balance too low to cover Mint Price + Gas.',
  copied: pt ? '✓ copiado' : '✓ copied',
};
---

<Layout
  title={layoutTitle}
  description={layoutDescription}
  lang={pt ? 'pt-BR' : 'en'}
  ogLocale={pt ? 'pt_BR' : 'en_US'}
  canonicalPath={pt ? '/pt-br/' : '/'}
>
  <Nav locale={locale} />
  <HeroSection locale={locale} />
  <ProofSection locale={locale} />
  <StatsBar locale={locale} />
  <TokenomicsSection locale={locale} />
  <ChartSection locale={locale} />
  <VerifySection locale={locale} />
  <Footer locale={locale} />

  <!-- Wallet selector modal (mobile deep links) -->
  <div id="wallet-modal" style="
    display:none;position:fixed;inset:0;z-index:9999;
    background:rgba(0,0,0,0.75);backdrop-filter:blur(8px);
    align-items:flex-end;justify-content:center;">
    <div style="
      background:#0a0a10;border:1px solid rgba(255,255,255,0.1);
      border-radius:28px 28px 0 0;padding:2rem 1.5rem 2.5rem;
      width:100%;max-width:480px;animation:slideUp 0.3s cubic-bezier(0.2,0.8,0.2,1);">
      <div style="width:40px;height:4px;background:rgba(255,255,255,0.2);border-radius:2px;margin:0 auto 1.5rem;"></div>
      <div style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.45);margin-bottom:0.5rem;">{i18n.connectWallet}</div>
      <div style="font-size:1.1rem;font-weight:700;margin-bottom:1.5rem;">{i18n.chooseWallet}</div>
      <div style="display:flex;flex-direction:column;gap:0.75rem;" id="wallet-options">
        <!-- MetaMask -->
        <button onclick="openWalletDeepLink('metamask')" style="
          display:flex;align-items:center;gap:1rem;
          background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);
          border-radius:16px;padding:1rem 1.25rem;cursor:pointer;color:#fff;
          font-family:inherit;font-size:0.95rem;font-weight:600;text-align:left;
          transition:border-color 0.2s;">
          <img src="https://raw.githubusercontent.com/MetaMask/brand-resources/master/SVG/SVG_MetaMask_Icon_Color.svg"
               width="36" height="36" alt="MetaMask" style="border-radius:8px;flex-shrink:0;" />
          <div>
            <div>MetaMask</div>
            <div style="font-size:0.7rem;color:rgba(255,255,255,0.45);font-weight:400;">{i18n.opensMetaMask}</div>
          </div>
        </button>
        <!-- Coinbase Wallet -->
        <button onclick="openWalletDeepLink('coinbase')" style="
          display:flex;align-items:center;gap:1rem;
          background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);
          border-radius:16px;padding:1rem 1.25rem;cursor:pointer;color:#fff;
          font-family:inherit;font-size:0.95rem;font-weight:600;text-align:left;
          transition:border-color 0.2s;">
          <img src="https://www.coinbase.com/assets/press/coinbase-mark-white-icon.png"
               width="36" height="36" alt="Coinbase Wallet" style="border-radius:8px;background:#1652f0;flex-shrink:0;padding:4px;" />
          <div>
            <div>Coinbase Wallet</div>
            <div style="font-size:0.7rem;color:rgba(255,255,255,0.45);font-weight:400;">{i18n.opensCoinbase}</div>
          </div>
        </button>
        <!-- Uniswap Wallet -->
        <button onclick="openWalletDeepLink('uniswap')" style="
          display:flex;align-items:center;gap:1rem;
          background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);
          border-radius:16px;padding:1rem 1.25rem;cursor:pointer;color:#fff;
          font-family:inherit;font-size:0.95rem;font-weight:600;text-align:left;
          transition:border-color 0.2s;">
          <img src="https://app.uniswap.org/favicon.png"
               width="36" height="36" alt="Uniswap Wallet" style="border-radius:8px;flex-shrink:0;" />
          <div>
            <div>Uniswap Wallet</div>
            <div style="font-size:0.7rem;color:rgba(255,255,255,0.45);font-weight:400;">{i18n.opensUniswap}</div>
          </div>
        </button>
        <!-- Rainbow -->
        <button onclick="openWalletDeepLink('rainbow')" style="
          display:flex;align-items:center;gap:1rem;
          background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);
          border-radius:16px;padding:1rem 1.25rem;cursor:pointer;color:#fff;
          font-family:inherit;font-size:0.95rem;font-weight:600;text-align:left;
          transition:border-color 0.2s;">
          <img src="https://rainbowme-res.cloudinary.com/image/upload/v1668070274/brand-assets/icon_s6hyya.png"
               width="36" height="36" alt="Rainbow" style="border-radius:8px;flex-shrink:0;" />
          <div>
            <div>Rainbow</div>
            <div style="font-size:0.7rem;color:rgba(255,255,255,0.45);font-weight:400;">{i18n.opensRainbow}</div>
          </div>
        </button>
      </div>
      <button onclick="closeWalletModal()" style="
        width:100%;margin-top:1rem;padding:0.875rem;border-radius:999px;
        background:transparent;border:1px solid rgba(255,255,255,0.15);
        color:rgba(255,255,255,0.6);font-family:inherit;font-size:0.875rem;
        cursor:pointer;">{i18n.cancel}</button>
    </div>
  </div>
  <style>
    @keyframes slideUp {
      from { transform: translateY(100%); }
      to   { transform: translateY(0); }
    }
    #wallet-modal.open { display: flex !important; }
  </style>

  <!-- ethers.js com SRI -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/ethers/6.13.1/ethers.umd.min.js"
          integrity="sha384-xeyyvbIlX+FahWHIZR6gjoC4A1i44cTBxZ330euRbtiXZwfcVDWVeOuJ4sGx8R2d"
          crossorigin="anonymous" referrerpolicy="no-referrer"></script>

  <!-- Main script -->
  <script define:vars={{ i18n, numberLocale }} is:inline>
    const CONTRACT_ADDRESS = "0x41f4ff3d45ded9c1332e4908f637b75fe83f5d6b";
    const SITE_URL = "neoflw.vercel.app";

    // ── Mobile wallet helpers ────────────────────────────────
    function isMobile() {
        return /android|iphone|ipad|ipod|mobile/i.test(navigator.userAgent);
    }

    function openWalletModal() {
        const modal = document.getElementById('wallet-modal');
        if (modal) modal.classList.add('open');
        document.body.style.overflow = 'hidden';
    }

    function closeWalletModal() {
        const modal = document.getElementById('wallet-modal');
        if (modal) modal.classList.remove('open');
        document.body.style.overflow = '';
    }

    // Close modal on backdrop click
    document.getElementById('wallet-modal')?.addEventListener('click', (e) => {
        if (e.target === e.currentTarget) closeWalletModal();
    });

    function openWalletDeepLink(wallet) {
        closeWalletModal();
        const encodedUrl = encodeURIComponent('https://' + SITE_URL);
        const links = {
            metamask: `https://metamask.app.link/dapp/${SITE_URL}`,
            coinbase:  `https://go.cb-w.com/dapp?cb_url=${encodedUrl}`,
            uniswap:   `https://wallet.uniswap.org/#/open-dapp?url=${encodedUrl}`,
            rainbow:   `https://rnbwapp.com/dapp?url=${encodedUrl}`,
        };
        window.location.href = links[wallet] || links.metamask;
    }
    const ABI = [
        "function getContractInfo() external view returns (uint256 currentSupply, uint256 maxSupply, uint256 mintPrice, uint256 mintAmount, bool mintEnabled, address bridge)",
        "function publicMint() external payable",
        "function hasPublicMinted(address user) external view returns (bool)",
        "function totalSupply() external view returns (uint256)",
        "function symbol() external view returns (string)"
    ];

    let provider, signer, contract;
    let userAddress = null;

    async function init() {
        // Default provider for read-only data (Base RPC)
        const baseRpc = "https://mainnet.base.org";
        const readProvider = new ethers.JsonRpcProvider(baseRpc);
        const readContract = new ethers.Contract(CONTRACT_ADDRESS, ABI, readProvider);

        try {
            const info = await readContract.getContractInfo();
            updateUI(info);
        } catch (e) {
            console.error("Failed to load contract info:", e);
            // Fallback to static info if RPC fails
            // BaseScan fallback will populate supply-count via updateLiveStats()
        }

        setupEventListeners();
        await tryAutoReconnect();
    }

    function updateUI(info) {
        const currentSupply = ethers.formatEther(info.currentSupply);
        const maxSupply = ethers.formatEther(info.maxSupply);
        const price = ethers.formatEther(info.mintPrice);
        const amount = ethers.formatEther(info.mintAmount);
        const enabled = info.mintEnabled;

        document.getElementById('supply-count').textContent = Number(currentSupply).toLocaleString(numberLocale);
        document.getElementById('info-amount').textContent = `${Number(amount).toLocaleString(numberLocale)} $NEOFLW`;
        document.getElementById('info-price').textContent = `${price} ETH`;

        const percentage = (Number(currentSupply) / Number(maxSupply)) * 100;
        document.getElementById('supply-bar').style.width = `${percentage}%`;

        if (!enabled) {
            const btn = document.getElementById('action-mint-btn');
            btn.disabled = true;
            btn.textContent = i18n.mintingDisabled;
        }
    }

    async function checkNetwork() {
        // Use raw window.ethereum to check chainId to avoid ethers v6 NETWORK_ERROR
        const chainId = await window.ethereum.request({ method: 'eth_chainId' });
        const targetChainId = '0x2105'; // 8453 in hex

        if (chainId !== targetChainId) {
            try {
                await window.ethereum.request({
                    method: 'wallet_switchEthereumChain',
                    params: [{ chainId: targetChainId }],
                });
            } catch (switchError) {
                if (switchError.code === 4902) {
                    await window.ethereum.request({
                        method: 'wallet_addEthereumChain',
                        params: [{
                            chainId: targetChainId,
                            chainName: 'Base Mainnet',
                            nativeCurrency: { name: 'Ether', symbol: 'ETH', decimals: 18 },
                            rpcUrls: ['https://mainnet.base.org'],
                            blockExplorerUrls: ['https://basescan.org']
                        }],
                    });
                } else {
                    throw switchError;
                }
            }
            // Small delay to let MetaMask update its internal state
            await new Promise(resolve => setTimeout(resolve, 1000));
        }
    }

    async function tryAutoReconnect() {
        const saved = localStorage.getItem('neoflw_addr');
        if (!saved || !window.ethereum) return;
        try {
            const accounts = await window.ethereum.request({ method: 'eth_accounts' });
            if (accounts[0]?.toLowerCase() === saved.toLowerCase()) {
                provider = new ethers.BrowserProvider(window.ethereum);
                signer = await provider.getSigner();
                userAddress = accounts[0];
                contract = new ethers.Contract(CONTRACT_ADDRESS, ABI, signer);
                const short = `${userAddress.slice(0,6)}...${userAddress.slice(-4)}`;
                const connBtn = document.getElementById('connect-btn');
                connBtn.innerHTML = `<span class="dot" style="background:var(--green)"></span> <span class="addr-txt">${short}</span>`;
                connBtn.classList.add('active');
                const hasMinted = await contract.hasPublicMinted(userAddress);
                const mintBtn = document.getElementById('action-mint-btn');
                if (hasMinted) { mintBtn.disabled = true; mintBtn.textContent = i18n.alreadyMinted; }
                else { mintBtn.textContent = i18n.mintNow; mintBtn.classList.add('connected'); }
            } else {
                localStorage.removeItem('neoflw_addr');
            }
        } catch (e) {
            localStorage.removeItem('neoflw_addr');
        }
    }

    async function toggleWallet() {
        if (userAddress) {
            // Disconnect logic (Clear app state)
            userAddress = null;
            signer = null;
            contract = null;
            localStorage.removeItem('neoflw_addr');

            const connBtn = document.getElementById('connect-btn');
            connBtn.innerHTML = `${i18n.connectWallet}`;
            connBtn.classList.remove('active');

            const mintBtn = document.getElementById('action-mint-btn');
            mintBtn.textContent = i18n.connectWalletToMint;
            mintBtn.classList.remove('connected');
            mintBtn.disabled = false;
            mintBtn.style.background = ""; // Reset success color if needed

            console.log("App state cleared.");
        } else {
            await connectWallet();
        }
    }

    async function connectWallet() {
        if (window.ethereum) {
            try {
                // 1. Request accounts FIRST — wallet must be connected before switching chain
                provider = new ethers.BrowserProvider(window.ethereum);
                const accounts = await provider.send("eth_requestAccounts", []);
                const addr = accounts[0];

                // 2. Switch/add Base network NOW that wallet is connected
                await checkNetwork();

                // 3. Re-fetch signer after potential network switch
                const signerInstance = await provider.getSigner();

                userAddress = addr;
                signer = signerInstance;
                contract = new ethers.Contract(CONTRACT_ADDRESS, ABI, signer);
                localStorage.setItem('neoflw_addr', userAddress);

                // Update Top Nav Button
                const shortAddr = `${userAddress.slice(0, 6)}...${userAddress.slice(-4)}`;
                const connBtn = document.getElementById('connect-btn');
                connBtn.innerHTML = `<span class="dot" style="background:var(--green)"></span> <span class="addr-txt">${shortAddr}</span>`;
                connBtn.classList.add('active');

                // Check status for Mint
                const hasMinted = await contract.hasPublicMinted(userAddress);
                const mintBtn = document.getElementById('action-mint-btn');

                if (hasMinted) {
                    mintBtn.disabled = true;
                    mintBtn.textContent = i18n.alreadyMinted;
                } else {
                    mintBtn.textContent = i18n.mintNow;
                    mintBtn.classList.add('connected');
                }

            } catch (error) {
                console.error("Connection failed:", error);
                let msg = error.message || "Failed to connect wallet.";
                if (error.code === 'ACTION_REJECTED' || error.code === 4001) msg = i18n.rejected;
                if (error.code === 'BAD_DATA') msg = i18n.networkError;
                alert(msg);
            }
        } else {
            // No window.ethereum — show mobile wallet selector or desktop install prompt
            if (isMobile()) {
                openWalletModal();
            } else {
                alert(i18n.installWallet);
            }
        }
    }

    async function doMint() {
        if (!window.ethereum) {
            if (isMobile()) {
                openWalletModal();
            } else {
                alert(i18n.walletNotFound);
            }
            return;
        }

        try {
            // If not connected, connectWallet handles accounts + network switch in correct order
            if (!signer) {
                await connectWallet();
                if (!signer) return;
            }

            // Wallet is connected — safe to check/switch network now
            await checkNetwork();

            const mintBtn = document.getElementById('action-mint-btn');
            mintBtn.textContent = i18n.checkingBalance;
            mintBtn.disabled = true;

            // Re-instantiate contract with signer
            contract = new ethers.Contract(CONTRACT_ADDRESS, ABI, signer);

            // Fetch balance and price for verification
            const balance = await provider.getBalance(userAddress);
            const info = await contract.getContractInfo();
            const price = info.mintPrice;

            console.log("Wallet Balance:", ethers.formatEther(balance), "ETH");
            console.log("Mint Price:", ethers.formatEther(price), "ETH");

            if (balance < price) {
                throw new Error(`Insufficient funds: You have ${Number(ethers.formatEther(balance)).toFixed(5)} ETH but need ${ethers.formatEther(price)} ETH + gas.`);
            }

            mintBtn.textContent = i18n.processingTx;

            // Call publicMint with MINT_PRICE
            const tx = await contract.publicMint({
                value: price
            });

            mintBtn.textContent = i18n.waitingConfirmation;
            const receipt = await tx.wait();

            if (receipt.status === 1) {
                mintBtn.textContent = i18n.success;
                mintBtn.style.background = "var(--green)";
                mintBtn.style.color = "#000";
                setTimeout(() => init(), 3000);
            } else {
                throw new Error("Transaction failed on-chain");
            }

        } catch (error) {
            console.error("Mint failed:", error);
            const mintBtn = document.getElementById('action-mint-btn');
            mintBtn.textContent = i18n.mintNow;
            mintBtn.disabled = false;

            let errorMsg = i18n.txFailed;

            // Detailed error handling
            if (error.code === 'ACTION_REJECTED' || error.code === 4001) {
                errorMsg = i18n.rejectedTx;
            } else if (error.code === 'BAD_DATA') {
                errorMsg = i18n.networkError;
            } else if (error.message && error.message.includes("Insufficient funds")) {
                errorMsg = error.message;
            } else if (error.message && error.message.includes("insufficient funds")) {
                errorMsg = i18n.lowBalance;
            } else if (error.reason) {
                errorMsg = `Contract error: ${error.reason}`;
            }

            alert(errorMsg);
        }
    }

    async function updateLiveStats() {
        const POOL = '0xba6f7f1d429c61e1714bd94a1c74414289fe52f1c14473ba005edfd042d3f014';
        const CONTRACT_ADDR = '0x41F4ff3d45DED9C1332e4908F637B75fe83F5d6B';

        function fmt(n) {
            if (n >= 1e9) return '$' + (n / 1e9).toFixed(2) + 'B';
            if (n >= 1e6) return '$' + (n / 1e6).toFixed(2) + 'M';
            if (n >= 1e3) return '$' + (n / 1e3).toFixed(1) + 'K';
            return '$' + n.toFixed(2);
        }

        try {
            // GeckoTerminal API — free, no key required
            const res = await fetch(`https://api.geckoterminal.com/api/v2/networks/base/pools/${POOL}`, {
                headers: { 'Accept': 'application/json' }
            });
            const json = await res.json();
            const attr = json.data.attributes;

            const price = parseFloat(attr.base_token_price_usd);
            const vol24 = parseFloat(attr.volume_usd.h24);
            const mcap = parseFloat(attr.fdv_usd || attr.market_cap_usd || 0);

            document.getElementById('stat-price').textContent = price < 0.01
                ? '$' + price.toFixed(6)
                : '$' + price.toFixed(4);
            document.getElementById('stat-volume').textContent = fmt(vol24);
            document.getElementById('stat-mcap').textContent = fmt(mcap);

            const badge = document.getElementById('stats-status');
            badge.style.opacity = '1';
        } catch (err) {
            console.warn('Live stats fetch failed:', err);
        }

        try {
            // BaseScan — total supply for On-chain Distribution card
            const MAX_SUPPLY = 1_000_000_000;
            const supplyRes = await fetch(`https://api.basescan.org/api?module=stats&action=tokensupply&contractaddress=${CONTRACT_ADDR}`);
            const supplyData = await supplyRes.json();
            if (supplyData.status === '1') {
                const supply = parseInt(supplyData.result) / 1e18;
                const pct = Math.round((supply / MAX_SUPPLY) * 100);

                const el = document.getElementById('supply-count');
                if (el) el.textContent = supply.toLocaleString(numberLocale);
                const bar = document.getElementById('supply-bar');
                if (bar) bar.style.width = `${pct}%`;

                // Hero card circulating bar
                const hcPct = document.getElementById('hc-circ-pct');
                if (hcPct) hcPct.textContent = pct + '%';
                const hcFill = document.getElementById('hc-bar-fill');
                if (hcFill) hcFill.style.width = pct + '%';
            }
        } catch (err) {
            console.warn('Supply fetch failed:', err);
        }
    }

    function setupEventListeners() {
        document.getElementById('connect-btn').addEventListener('click', toggleWallet);
        document.getElementById('action-mint-btn').addEventListener('click', doMint);

        if (window.ethereum) {
            window.ethereum.on('chainChanged', () => window.location.reload());
            window.ethereum.on('accountsChanged', () => window.location.reload());
        }

        // Sync On-Chain Data every 60s
        updateLiveStats();
        setInterval(updateLiveStats, 60000);
    }

    function copyAddr() {
        const addr = document.getElementById('addr').textContent.trim()
        navigator.clipboard.writeText(addr).then(() => {
            const btn = document.querySelector('.chip-copy')
            const orig = btn.textContent
            btn.textContent = i18n.copied
            btn.style.color = 'var(--green)'
            setTimeout(() => { btn.textContent = orig; btn.style.color = ''; }, 2000)
        })
    }

    // Initialize on load
    window.addEventListener('DOMContentLoaded', init);
  </script>
</Layout>
